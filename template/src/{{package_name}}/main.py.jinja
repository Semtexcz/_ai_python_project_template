"""Runtime entry point for {{ project_name }}."""

{% if project_kind == "cli" -%}
from typing import Annotated

import typer
from rich.console import Console

from . import __version__
from .config import load_config
from .core import run_application
from .errors import ApplicationError
from .logging import configure_logging

console = Console()
error_console = Console(stderr=True)
app = typer.Typer(
    add_completion=False,
    help="{{ project_description }}.",
    invoke_without_command=True,
    no_args_is_help=False,
)


def _version_callback(value: bool) -> None:
    if value:
        console.print(__version__)
        raise typer.Exit()


@app.callback(invoke_without_command=True)
def run(
    ctx: typer.Context,
    version: Annotated[
        bool,
        typer.Option(
            "--version",
            callback=_version_callback,
            help="Show the application version and exit.",
            is_eager=True,
        ),
    ] = False,
    verbose: Annotated[
        bool,
        typer.Option("--verbose", "-v", help="Enable debug logging."),
    ] = False,
    quiet: Annotated[
        bool,
        typer.Option("--quiet", "-q", help="Only print essential output."),
    ] = False,
) -> None:
    """Run the application."""
    _ = version
    if ctx.invoked_subcommand is not None:
        return

    config = load_config(debug_override=verbose)
    configure_logging(config.debug)

    try:
        result = run_application(config)
    except ApplicationError as exc:
        error_console.print(f"[red]Error:[/red] {exc}")
        raise typer.Exit(1) from exc

    if not quiet:
        console.print(result.message)


def main() -> None:
    """Run the command-line application."""
    app()
{%- elif project_kind == "api" -%}
import os

import uvicorn
from fastapi import FastAPI

from .config import AppConfig, load_config
from .logging import configure_logging


def create_app(config: AppConfig | None = None) -> FastAPI:
    """Create the FastAPI application."""
    active_config = config or load_config()
    app = FastAPI(title=active_config.name, version=active_config.version)

    @app.get("/health")
    def health() -> dict[str, str]:
        return {
            "status": "ok",
            "name": active_config.name,
            "version": active_config.version,
            "environment": active_config.environment,
        }

    return app


app = create_app()


def main() -> None:
    """Run the local API development server."""
    config = load_config()
    configure_logging(config.debug)
    host = os.getenv("{{ package_name | upper }}_HOST", "127.0.0.1")
    port = int(os.getenv("{{ package_name | upper }}_PORT", "8000"))
    uvicorn.run("{{ package_name }}.main:app", host=host, port=port, reload=config.debug)
{%- elif project_kind == "tui" -%}
from textual.app import App, ComposeResult
from textual.widgets import Footer, Header, Static

from .config import load_config
from .core import run_application


class ProjectApp(App[None]):
    """Minimal Textual application shell."""

    TITLE = "{{ project_name }}"
    CSS = """
    Screen {
        align: center middle;
    }

    #status {
        width: 70%;
        min-width: 40;
        border: solid $accent;
        padding: 1 2;
    }
    """

    def compose(self) -> ComposeResult:
        config = load_config()
        result = run_application(config)
        yield Header()
        yield Static(result.message, id="status")
        yield Footer()


def main() -> None:
    """Run the terminal UI."""
    ProjectApp().run()
{%- else -%}
import sys

from .config import load_config
from .core import run_application
from .errors import ApplicationError
from .logging import configure_logging


def main() -> None:
    """Run the starter application."""
    config = load_config()
    configure_logging(config.debug)

    try:
        result = run_application(config)
    except ApplicationError as exc:
        print(f"Error: {exc}", file=sys.stderr)
        raise SystemExit(1) from exc

    print(result.message)
