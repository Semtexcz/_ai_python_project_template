"""Application configuration helpers."""

import os
from dataclasses import dataclass


@dataclass(frozen=True)
class AppConfig:
    """Runtime configuration loaded from the environment."""

    name: str
    version: str
    environment: str
    debug: bool


def _read_bool(value: str | None, *, default: bool = False) -> bool:
    if value is None:
        return default
    return value.strip().lower() in {"1", "true", "yes", "on"}


def load_config(*, debug_override: bool | None = None) -> AppConfig:
    """Load configuration from environment variables."""
    debug = _read_bool(os.getenv("{{ package_name | upper }}_DEBUG"))
    if debug_override is not None:
        debug = debug_override

    return AppConfig(
        name="{{ project_name }}",
        version="{{ initial_version }}",
        environment=os.getenv("{{ package_name | upper }}_ENV", "development"),
        debug=debug,
    )
