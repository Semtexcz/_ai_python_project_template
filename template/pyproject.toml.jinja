[build-system]
requires = ["setuptools>=64"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project_slug }}"
version = "{{ initial_version }}"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
authors = [
  { name = "{{ author_name }}", email = "{{ author_email }}" }
]
{% if project_kind == "cli" %}
dependencies = [
  "rich>=13.7",
  "typer>=0.12",
]
{% elif project_kind == "api" %}
dependencies = [
  "fastapi>=0.115",
  "uvicorn>=0.30",
]
{% elif project_kind == "tui" %}
dependencies = [
  "rich>=13.7",
  "textual>=0.80",
]
{% else %}
dependencies = []
{% endif %}

{% if project_kind != "library" -%}
[project.scripts]
"{{ project_slug }}" = "{{ package_name }}.main:main"
{% endif %}

[dependency-groups]
{% if project_kind == "api" %}
dev = [
  "httpx>=0.28",
  "httpx2>=2.5",
  "pytest>=8.0",
  "pytest-cov>=5.0",
  "ruff>=0.6",
  "mypy>=1.10",
  "pre-commit>=3.6",
]
{% else %}
dev = [
  "pytest>=8.0",
  "pytest-cov>=5.0",
  "ruff>=0.6",
  "mypy>=1.10",
  "pre-commit>=3.6",
]
{% endif %}

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = [
  "--strict-config",
  "--strict-markers",
]

[tool.ruff]
line-length = 100
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP", "SIM"]
ignore = []

[tool.mypy]
python_version = "{{ python_version }}"
strict = true
mypy_path = "src"

[tool.coverage.run]
branch = true
source = ["{{ package_name }}"]

[tool.coverage.report]
show_missing = true
skip_covered = true

[tool.setuptools.packages.find]
where = ["src"]
